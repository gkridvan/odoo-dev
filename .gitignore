# =============================================================================
# .gitignore for Odoo Project
# =============================================================================

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
dist/
build/

# Virtual Environment
venv/
env/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Docker volumes (managed by Docker, not tracked in git)
# The named volumes in docker-compose.yml are stored by Docker,
# not in the project folder, so they won't appear here.

# Odoo filestore (if somehow created locally)
filestore/

# Logs
*.log

# Environment variables (never commit secrets!)
.env

# =============================================================================
# Marzipano 360 tours - tiles (images tuiles volumineuses, gérées hors git)
# Les fichiers index.html, data.js, vendor/ sont trackés (code)
# Les tiles/ (images JPG/PNG pyramidales) sont à gérer via Git LFS ou externalisées
# =============================================================================
custom-addons/website_360_view/static/src/tours/*/tiles/

# Scripts de debug temporaires (racine du projet)
debug_360.py
fix_360_template.py
check_360.py
check_dims.py
find_panoramas.py
fix_reunion.py
setup_360_local.py

# ML Analysis - environnement virtuel Python
ml-analysis/venv/
ml-analysis/.venv/
