<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Dashboard action: Prospects patrimoniaux -->
    <record id="action_prospects_patrimoine" model="ir.actions.act_window">
        <field name="name">Prospects Patrimoniaux</field>
        <field name="res_model">crm.lead</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('x_segment', '!=', False)]</field>
        <field name="context">{'search_default_group_segment': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucun prospect patrimonial pour le moment.
            </p>
            <p>Importez vos prospects via le script <strong>generate_patrimoine_data.py</strong>.</p>
        </field>
    </record>

    <!-- Menu entry under CRM -->
    <menuitem id="menu_prospects_patrimoine"
              name="Prospects Patrimoniaux"
              parent="crm.crm_menu_root"
              action="action_prospects_patrimoine"
              sequence="15"/>

</odoo>
