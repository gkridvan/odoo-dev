<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_360" model="ir.ui.view">
        <field name="name">product.template.form.360</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Visite 360°" name="page_360_view">
                    <group string="Tour Marzipano">
                        <group>
                            <field name="x_marzipano_enabled"
                                   widget="boolean_toggle"
                                   string="Activer la visite 360°"/>
                            <field name="x_marzipano_tour_id"
                                   string="Tour Marzipano"
                                   invisible="not x_marzipano_enabled"
                                   options="{'no_quick_create': True}"/>
                        </group>
                        <div colspan="2" class="alert alert-info" role="alert"
                             invisible="not x_marzipano_enabled">
                            Gérez les tours disponibles dans
                            <strong>Site Web → Configuration → Tours 360°</strong>.
                        </div>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>