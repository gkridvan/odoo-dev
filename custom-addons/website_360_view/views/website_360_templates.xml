<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="product_360_viewer"
              inherit_id="website_sale.product"
              name="360 Product Viewer">

        <xpath expr="//div[@id='product_detail_main']" position="before">
            <t t-if="product.x_marzipano_enabled and product.x_marzipano_tour_id">
                <div class="o_marzipano_iframe_wrapper mb-3">
                    <iframe
                        t-attf-src="/website_360_view/static/src/tours/#{product.x_marzipano_tour_id.name}/index.html"
                        allowfullscreen="1"
                        frameborder="0"/>
                </div>
            </t>
        </xpath>

    </template>
</odoo>